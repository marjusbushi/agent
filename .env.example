# --- DIS Bot API (Zero Absolute) ---
DIS_BASE_URL=https://stage.zeroabsolute.dev/api/bot/v1
DIS_BOT_TOKEN=your-dis-sanctum-token-here

# --- Zoho ---
ZOHO_CLIENT_ID=your-client-id
ZOHO_CLIENT_SECRET=your-client-secret
