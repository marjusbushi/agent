# === OpenClaw Agent - Environment Variables ===
# Copy to .env and fill in values: cp .env.example .env

# --- Server ---
SERVER_IP=195.201.218.179
SSH_USER=root

# --- Telegram ---
TELEGRAM_BOT_TOKEN_CLAW=your_bot_token_here
TELEGRAM_BOT_TOKEN_MELISA=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_AI_API_KEY=your-gemini-key-here
MOONSHOT_API_KEY=your-moonshot-key-here

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# --- Kommo CRM ---
KOMMO_SUBDOMAIN=infozeroabsolutecom
KOMMO_ACCESS_TOKEN=your-kommo-token-here
KOMMO_WEBHOOK_SECRET=your-webhook-secret-here
